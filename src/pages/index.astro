---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const xSocial = SOCIALS.find((s) => s.NAME === "x")!;

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .filter(post => !post.data.tags?.includes(SITE.BLOG_EXCLUDED_TAG))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const homepageProjectOrder = ["omnichannel", "learning-platform", "nesra"];
const homepageProjectRank = (slug: string) => {
  const rank = homepageProjectOrder.indexOf(slug);
  return rank === -1 ? homepageProjectOrder.length : rank;
};

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .filter(project => project.data.featured)
  .sort((a, b) =>
    homepageProjectRank(a.slug) - homepageProjectRank(b.slug)
  )
  .slice(0,SITE.NUM_PROJECTS_ON_HOMEPAGE);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Mufid <span class="text-xl">👋🏻</span> 
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            Founder of Entrefine, an omnichannel platform for Indonesian businesses.
            I'm an engineer who loves building systems — in data, AI, and software.
          </p>
          <p class="animate">
            Before this I spent four years as a data engineer, software engineer, and product manager. I build end-to-end, from architecture decisions to shipping product.
          </p>
          <p class="animate">
            This site is where I document what I'm learning along the way.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Latest posts
          </h5>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
          If you want to get in touch with me, reach out on <Link href={xSocial.HREF} external aria-label={`${SITE.NAME} on ${xSocial.NAME}`}><span class="italic">x</span></Link> or send me an email.
        </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              email
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
